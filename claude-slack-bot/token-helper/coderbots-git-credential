#!/usr/bin/env bash
# git credential helper for github.com — returns a fresh bot token on every op.
#
# git invokes this with an operation arg ("get"/"store"/"erase") and a request
# on stdin. We only answer "get": print a username + a just-refreshed token from
# coderbots-token (which pulls from Central when the cache is near expiry). git
# consults this on EVERY authenticated operation, so long-running sessions always
# push/pull with a valid token. store/erase are no-ops (we don't persist here).
set -euo pipefail

[ "${1:-}" = "get" ] || exit 0

# coderbots-token lives alongside this script; prefer that copy, fall back to PATH.
here="$(cd "$(dirname "$0")" && pwd)"
token_bin="$here/coderbots-token"
[ -x "$token_bin" ] || token_bin="coderbots-token"

tok="$("$token_bin" 2>/dev/null || true)"
[ -n "$tok" ] || exit 0  # no token → git falls through / prompts; never emit empty creds

printf 'username=x-access-token\npassword=%s\n' "$tok"
