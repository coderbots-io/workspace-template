#!/usr/bin/env bash
# git credential helper for github.com — returns a fresh bot token on every op.
#
# git invokes this with an operation arg ("get"/"store"/"erase") and a request
# on stdin. We only answer "get": print a username + a just-refreshed token from
# coderbots-token (which pulls from Central when the cache is near expiry). git
# consults this on EVERY authenticated operation, so long-running sessions always
# push/pull with a valid token. store/erase are no-ops (we don't persist here).
#
# A bot token only covers ONE installation, so we pass the repo's owner to
# coderbots-token (which mints/caches per owner). git supplies the owner/repo in
# the `path=` request line ONLY when credential.useHttpPath=true — bridge.py sets
# that. Without it path is empty and we fall back to the default/user token.
set -euo pipefail

[ "${1:-}" = "get" ] || exit 0

# Read the request from stdin: key=value lines, terminated by a blank line.
host=""
cpath=""
while IFS='=' read -r key value; do
  [ -z "$key" ] && break
  case "$key" in
    host) host="$value" ;;
    path) cpath="$value" ;;
  esac
done

# Only ever vend the bot token for github.com.
case "$host" in
  github.com|"") ;;
  *) exit 0 ;;
esac

# path looks like "owner/repo.git" (or "owner/repo"). Extract owner + repo.
owner=""
repo=""
if [ -n "$cpath" ]; then
  cpath="${cpath#/}"
  owner="${cpath%%/*}"
  rest="${cpath#*/}"
  repo="${rest%%/*}"
  repo="${repo%.git}"
fi

# coderbots-token lives alongside this script; prefer that copy, fall back to PATH.
here="$(cd "$(dirname "$0")" && pwd)"
token_bin="$here/coderbots-token"
[ -x "$token_bin" ] || token_bin="coderbots-token"

args=()
[ -n "$owner" ] && args+=(--owner "$owner")
[ -n "$repo" ] && args+=(--repo "$repo")

# ${args[@]+...} guards an empty array under `set -u` (older bash).
tok="$("$token_bin" ${args[@]+"${args[@]}"} 2>/dev/null || true)"
[ -n "$tok" ] || exit 0  # no token → git falls through / prompts; never emit empty creds

printf 'username=x-access-token\npassword=%s\n' "$tok"
